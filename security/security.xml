<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="module_category_installment" model="ir.module.category">
        <field name="name">Installments</field>
        <field name="description">Helps manage customer payment plans.</field>
        <field name="sequence">20</field>
    </record>

    <record id="privilege_installment_access" model="res.groups.privilege">
        <field name="name">Installment Access Control</field>
        <field name="category_id" ref="module_category_installment"/>
    </record>

    <record id="group_installment_user" model="res.groups">
        <field name="name">User</field>
        <field name="privilege_id" ref="privilege_installment_access"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_installment_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="privilege_id" ref="privilege_installment_access"/>
        <field name="implied_ids" eval="[(4, ref('installment.group_installment_user'))]"/>
    </record>

    <record id="rule_installment_user" model="ir.rule">
        <field name="name">User: Own Installments Only</field>
        <field name="model_id" ref="model_installment_installment"/>
        <field name="domain_force">[('create_uid', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('installment.group_installment_user'))]"/>
    </record>

    <record id="rule_installment_manager" model="ir.rule">
        <field name="name">Manager: All Installments</field>
        <field name="model_id" ref="model_installment_installment"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('installment.group_installment_manager'))]"/>
    </record>

</odoo>